# ===========================================
# تنظیمات پایه
# ===========================================
APP_NAME="AI Debate & Project Management System"
DEBUG=true
ENVIRONMENT=development

# ===========================================
# API Keys
# کلیدهای API خود را از سایت‌های مربوطه دریافت کنید
# ===========================================

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude - https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# Google Gemini - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# OpenRouter (Optional) - https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-...

# Groq (Optional) - https://console.groq.com/
GROQ_API_KEY=gsk_...

# ===========================================
# تنظیمات سرور
# ===========================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ===========================================
# تنظیمات دیتابیس
# ===========================================
DATABASE_URL=sqlite:///./data/app.db

# ===========================================
# تنظیمات امنیتی
# ===========================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# تنظیمات CORS
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ===========================================
# تنظیمات پردازش AI
# ===========================================
MAX_TOKENS_PER_MODEL=4000
MAX_PROMPT_LENGTH=100000
REQUEST_TIMEOUT=120

# ===========================================
# ضبط ویدئوی صفحه + تبدیل گفتار به متن (بازرس ویژه)
# ===========================================
# مدل چندوجهی برای transcription صوت ضبط ویدئو (باید audio/inline را پشتیبانی کند).
# پیش‌فرض: gemini-2.5-flash
AUDIO_TRANSCRIPTION_MODEL=gemini-2.5-flash

# ===========================================
# Cloud Code (Claude Code OAuth) — موتور پردازش پرامپت برای بازرس ویژه
# ===========================================
# توکن OAuth اشتراک Claude Code که با `claude setup-token` ساخته می‌شود.
# همین توکن در claude_runner / GitHub Actions هم استفاده می‌شود — برای
# اینکه چت بازرس ویژه از سهمیه‌ی اشتراک کاربر استفاده کند نه از API
# metered. اگر تنظیم نشود، گزینهٔ «Cloud Code» در UI به‌صورت disabled
# نمایش داده می‌شود و کاربر باید از Local AI استفاده کند.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# توکن دیگری که برای endpoint های external-tool استفاده می‌شود
# (مثلاً claude_runner workflow برای write-back به oversight). همان
# value را باید در `EXTERNAL_TOOL_TOKEN` secret در GitHub repo هم بگذاری.
EXTERNAL_TOOL_TOKEN=change-me-to-a-random-secret
